<Window x:Class="Worms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Worms" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FF0F2A3D">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Червяки" 
                   FontSize="72" 
                   FontWeight="Bold" 
                   Foreground="White"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   FontFamily="Arial"/>

        <StackPanel Grid.Row="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Margin="0,20">
            <Button x:Name="StartGameButton" 
                    Content="Начать игру" 
                    Width="200" 
                    Height="50" 
                    FontSize="20"
                    Margin="0,10"
                    Background="#FF1E90FF" 
                    Foreground="White"
                    BorderThickness="0"
                    Click="StartGameButton_Click"/>

            <Button x:Name="ExitButton" 
                    Content="Выйти" 
                    Width="200" 
                    Height="50" 
                    FontSize="20"
                    Margin="0,10"
                    Background="#FFDC143C" 
                    Foreground="White"
                    BorderThickness="0"
                    Click="ExitButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2" 
                   Text="Червяки v1.0" 
                   FontSize="14" 
                   Foreground="Black"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom"
                   Margin="0,20"/>
    </Grid>
</Window>