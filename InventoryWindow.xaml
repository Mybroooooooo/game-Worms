<Window x:Class="Worms.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Инвентарь" 
        Height="500" 
        Width="350"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FF2D2D30"
        ShowInTaskbar="False"
        Focusable="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF007ACC" Height="50">
            <Grid>
                <TextBlock Text="ИНВЕНТАРЬ" 
                           Foreground="White" 
                           FontSize="22" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentWormName, StringFormat='{}{0}'}"
                           Foreground="White"
                           FontSize="14"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="10" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="WeaponsList">
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#FF252526" Margin="10,5,10,5" CornerRadius="5" Padding="10">
            <StackPanel>
                <TextBlock Text="Управление:" 
                           Foreground="White" 
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBlock Text="• Клик мышью — выбрать оружие" 
                           Foreground="#FFCCCCCC"
                           FontSize="12"/>
                <TextBlock Text="• F — использовать выбранное оружие" 
                           Foreground="#FFCCCCCC"
                           FontSize="12"/>
                <TextBlock Text="• I — открыть/закрыть инвентарь" 
                           Foreground="#FFCCCCCC"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="#FF252526" Height="40">
            <TextBlock x:Name="StatusText" 
                       Text="Выберите оружие кликом мыши"
                       Foreground="#FFCCCCCC"
                       FontSize="12"
                       Margin="15,0"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>